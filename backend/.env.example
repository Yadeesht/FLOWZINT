# =========================================================================
# EduFlow AI Backend - Environment Configuration
# Fill in your credentials below. Keep this file secret.
# =========================================================================

# 1. Azure OpenAI API Configuration
AZURE_OPENAI_API_KEY=YOUR_AZURE_OPENAI_API_KEY
AZURE_OPENAI_ENDPOINT=https://YOUR-RESOURCE-NAME.openai.azure.com/
AZURE_OPENAI_DEPLOYMENT_NAME=YOUR_GPT4o_OR_GPT35_DEPLOYMENT_NAME
AZURE_OPENAI_API_VERSION=2024-02-15-preview

# 2. Twilio WhatsApp Configuration
TWILIO_ACCOUNT_SID=YOUR_TWILIO_ACCOUNT_SID
TWILIO_AUTH_TOKEN=YOUR_TWILIO_AUTH_TOKEN
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# 3. EmailJS API Credentials (for admin escalation emails)
EMAILJS_SERVICE_ID=YOUR_EMAILJS_SERVICE_ID
EMAILJS_TEMPLATE_ID=YOUR_EMAILJS_TEMPLATE_ID
EMAILJS_PUBLIC_KEY=YOUR_EMAILJS_PUBLIC_KEY

# 4. Local Application Settings
PORT=8000
FRONTEND_URL=http://localhost:3000
